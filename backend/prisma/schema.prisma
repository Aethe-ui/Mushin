// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DailyMetric {
  id             BigInt   @id @default(autoincrement())
  userId         String   @map("user_id")
  entryDate      DateTime @db.Date @map("entry_date")
  focusHours     Decimal  @db.Decimal @map("focus_hours")
  workoutMinutes Decimal  @db.Decimal @map("workout_minutes")
  restHours      Decimal  @db.Decimal @map("rest_hours")
  score          Decimal  @db.Decimal
  xp             Int
  state          String
  explanation    String
  createdAt      DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  @@unique([userId, entryDate], map: "daily_metrics_user_date_key")
  @@index([userId, entryDate(sort: Desc)], map: "daily_metrics_user_date_idx")
  @@map("daily_metrics")
}
